# ==============================================================================
# Ethara Seat Allocation & Project Mapping System — Environment Variables
# ==============================================================================

# Application
APP_NAME=Ethara Seat Allocation & Project Mapping System
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ethara_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# CORS (JSON array of allowed origins)
CORS_ORIGINS=["http://localhost:5173"]

# AI / Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-pro
